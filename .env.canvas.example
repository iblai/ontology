# .env.canvas — credentials for the mcp-canvas container (Canvas LMS)
# Copy to .env.canvas and fill in. Only this container ever sees these.
#   cp .env.canvas.example .env.canvas
#
# CANVAS_BASE_URL: instance root ONLY — no trailing slash, no /api/v1
#                  (server.py appends /api/v1 itself)
CANVAS_BASE_URL=https://ibleducation.instructure.com
# CANVAS_API_TOKEN: personal access token (Account > Settings >
#                   Approved Integrations > + New Access Token).
#                   Must be an ADMIN-scoped account to look up users by SIS id.
CANVAS_API_TOKEN=paste-your-token-here
