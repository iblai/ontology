# ============================================================
# .env.example — environment template for the iblai-ontology stack
#
# Copy to .env and fill in real values. NEVER commit real secrets.
#   cp .env.example .env
#
# Per-MCP-server credentials are split into .env.mcp / .env.canvas /
# .env.slate / .env.navigate / .env.ldap so each MCP container only sees
# the secrets it needs (credential isolation). The variables below cover
# all of them; distribute as appropriate.
# ============================================================

# PeopleSoft Oracle (read-only credentials provided by university)
PEOPLESOFT_DB_HOST=changeme.internal.university.edu
PEOPLESOFT_DB_PORT=1521
PEOPLESOFT_DB_NAME=CSPRD
PEOPLESOFT_RO_USER=iblai_readonly
PEOPLESOFT_RO_PASSWORD=<provided-by-university>

# Canvas LMS
CANVAS_BASE_URL=https://changeme.instructure.com
CANVAS_API_TOKEN=<generated-by-canvas-admin>

# Slate CRM
SLATE_BASE_URL=https://apply.changeme.edu
SLATE_API_KEY=<provided-by-slate-admin>

# Local iblai-ontology DB
ONTOLOGY_DB_PASSWORD=<generated-during-setup>

# Microsoft Entra ID
ENTRA_TENANT_ID=<university-tenant-id>
ENTRA_CLIENT_ID=<iblai-ontology-app-client-id>

# Public domain served by Caddy (e.g., ontology.university.edu lives under this)
ONTOLOGY_DOMAIN=changeme.edu

# Caddy will auto-provision TLS via Let's Encrypt
# or use a university-provided certificate.
