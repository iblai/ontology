# .env.mcp — mcp-toolbox (databases via config/tools.yaml)
PEOPLESOFT_DB_HOST=changeme.internal.edu
PEOPLESOFT_DB_PORT=1521
PEOPLESOFT_DB_NAME=CSPRD
PEOPLESOFT_RO_USER=iblai_readonly
PEOPLESOFT_RO_PASSWORD=changeme
ONTOLOGY_DB_USER=ontology
ONTOLOGY_DB_PASSWORD=change-me-any-strong-password

# Generic remote client Postgres (source: client-postgres in tools.yaml).
# Point these at ANY reachable Postgres; use a read-only role
# (see docs/read-only-db-user.md). Host may be a DNS name, IP, or a
# Docker network hostname if mcp-toolbox shares that network.
CLIENT_POSTGRES_HOST=changeme.db.example.com
CLIENT_POSTGRES_PORT=5432
CLIENT_POSTGRES_NAME=appdb
CLIENT_POSTGRES_RO_USER=ontology_ro
CLIENT_POSTGRES_RO_PASSWORD=changeme

# Generic remote client MySQL (source: client-mysql in tools.yaml).
# Point these at ANY reachable MySQL; use a read-only user
# (GRANT SELECT ON <db>.*). Host may be a DNS name, IP, or Docker
# network hostname if mcp-toolbox shares that network.
CLIENT_MYSQL_HOST=changeme.mysql.example.com
CLIENT_MYSQL_PORT=3306
CLIENT_MYSQL_NAME=appdb
CLIENT_MYSQL_RO_USER=ontology_ro
CLIENT_MYSQL_RO_PASSWORD=changeme
