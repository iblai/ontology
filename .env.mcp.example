# .env.mcp — mcp-toolbox (databases via config/tools.yaml)
PEOPLESOFT_DB_HOST=changeme.internal.edu
PEOPLESOFT_DB_PORT=1521
PEOPLESOFT_DB_NAME=CSPRD
PEOPLESOFT_RO_USER=iblai_readonly
PEOPLESOFT_RO_PASSWORD=changeme
ONTOLOGY_DB_USER=ontology
ONTOLOGY_DB_PASSWORD=change-me-any-strong-password

# Generic remote client Postgres (source: client-postgres in tools.yaml).
# Point these at ANY reachable Postgres; use a read-only role
# (see docs/read-only-db-user.md). Host may be a DNS name, IP, or a
# Docker network hostname if mcp-toolbox shares that network.
CLIENT_DB_HOST=changeme.db.example.com
CLIENT_DB_PORT=5432
CLIENT_DB_NAME=appdb
CLIENT_DB_RO_USER=ontology_ro
CLIENT_DB_RO_PASSWORD=changeme
