# Ontology Console — environment

# REST API base. Unset (or empty) → the console runs on its in-browser mock API.
# Point it at the Django backend to use real data. The browser calls this URL
# directly (cross-origin), so the backend must allow this origin via CORS
# (ONTOLOGY_CORS_ORIGINS on the backend — see the repo-root .env.example).
# NEXT_PUBLIC_ONTOLOGY_API_URL=http://localhost:8000

# Auth is taken from localStorage at request time (set by the ibl.ai SSO flow):
#   dm_token       → sent as `Authorization: Token <dm_token>`
#   edx_jwt_token  → sent as `X-Edx-Jwt: <edx_jwt_token>`
# With neither present, enable ONTOLOGY_API_DEV_ALLOW_ANON on the backend.

# ibl.ai SSO (wired later via /iblai-vibe-auth)
# NEXT_PUBLIC_MAIN_TENANT_KEY=
# NEXT_PUBLIC_API_BASE_URL=https://api.iblai.app
# NEXT_PUBLIC_AUTH_URL=https://login.iblai.app
