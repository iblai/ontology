# .env  (repo root) — copy to .env :  cp .env.root.example .env
# Consumed by docker-compose ${...} interpolation and the gateway/admin containers.
ONTOLOGY_DB_PASSWORD=change-me-any-strong-password
# Static bearer token for the ChromaDB vector store (#2146). Required: the
# vector-store, sync-engine, and gateway all read it. Generate one strong,
# random value, e.g.  openssl rand -hex 32
CHROMA_TOKEN=change-me-any-strong-token
ENTRA_TENANT_ID=leave-blank-if-not-testing-auth
ENTRA_CLIENT_ID=leave-blank-if-not-testing-auth
